generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  permissions Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users User[]
}

model User {
  id          String   @id @default(uuid())
  fullName    String
  email       String   @unique
  password    String?
  department  String?
  avatar      String?
  status      String   @default("Active")
  permissions Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  roleId String?
  role   Role?   @relation(fields: [roleId], references: [id], onDelete: SetNull)

  jobsAssigned       Job[]
  uploadedDocuments  Document[]          @relation("UploadedDocuments")
  complianceSections ComplianceSection[]
}

model Service {
  id            String   @id @default(uuid())
  title         String
  description   String
  status        String   @default("Active")
  category      String
  departments   String[] @default([])
  assignedRoles String[] @default([])
  usageCount    Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  jobs Job[]
}

model Job {
  id                 String   @id @default(uuid())
  jobNumber          String   @unique
  serviceType        String
  assignedPerson     String?
  jobDetails         String
  specialDescription String?
  clientName         String
  email              String
  startingPoint      String
  ckNumber           String?
  contactNumber      String?
  address            String?
  status             String   @default("Created")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  assignedUserId String?
  assignedUser   User?   @relation(fields: [assignedUserId], references: [id], onDelete: SetNull)

  serviceId String?
  service   Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  documents Document[]
}

model ComplianceSection {
  id          String   @id @default(uuid())
  title       String
  description String?
  type        String   @default("standard")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  documents Document[]
}

model Document {
  id           String   @id @default(uuid())
  fileName     String
  originalName String
  fileType     String
  fileSize     Int
  filePath     String
  uploadedBy   String?
  category     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  uploadedByUserId String?
  uploadedByUser   User?   @relation("UploadedDocuments", fields: [uploadedByUserId], references: [id], onDelete: SetNull)

  jobId String?
  job   Job?    @relation(fields: [jobId], references: [id], onDelete: Cascade)

  complianceSectionId String?
  complianceSection   ComplianceSection? @relation(fields: [complianceSectionId], references: [id], onDelete: Cascade)

  reportGroupId     String?
  reportCompany     String?
  reportYear        String?
  reportDescription String?

  @@index([jobId])
  @@index([complianceSectionId])
  @@index([reportGroupId])
}

model Company {
  id                  Int                  @id @default(autoincrement())
  name                String               @db.VarChar(255)
  createdAt           DateTime             @default(now()) @map("created_at")
  financialStatements FinancialStatement[]

  @@map("companies")
}

model FinancialStatement {
  id          Int             @id @default(autoincrement())
  companyId   Int             @map("company_id")
  year        Int
  description String?
  createdAt   DateTime        @default(now()) @map("created_at")
  company     Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  files       StatementFile[]

  @@unique([companyId, year])
  @@map("financial_statements")
}

model StatementFile {
  id           Int                @id @default(autoincrement())
  statementId  Int                @map("statement_id")
  originalName String             @map("original_name") @db.VarChar(255)
  storedName   String             @map("stored_name") @db.VarChar(255)
  filePath     String             @map("file_path")
  fileType     String?            @map("file_type") @db.VarChar(50)
  fileSize     BigInt?            @map("file_size")
  uploadedAt   DateTime           @default(now()) @map("uploaded_at")
  statement    FinancialStatement @relation(fields: [statementId], references: [id], onDelete: Cascade)

  @@map("statement_files")
}
